# Keep host-specific and generated cruft out of the build context so `COPY . .`
# can't clobber the container's nimby-installed packages / generated nim.cfg.
.git
.DS_Store

# Host nim.cfg has absolute /Users/... --path entries (from `nimby ... -g`) that
# don't exist in the image; let the in-container `nimby sync` own nim.cfg.
nim.cfg

# Build outputs / caches.
out/
tmp/
nimcache/
tools/.venv/
**/__pycache__/

# nimby-installed dependency package dirs (mirrors .gitignore); the image
# reinstalls these via `nimby sync nimby.lock`.
/bitworld/
/bumpy/
/chroma/
/crunchy/
/curly/
/dx12/
/flatty/
/fluffy/
/jsony/
/libcurl/
/metal4/
/mummy/
/nimsimd/
/opengl/
/paddy/
/pixie/
/shady/
/silky/
/supersnappy/
/taggy/
/urlly/
/vk14/
/vmath/
/webby/
/whisky/
/windy/
/ws/
/zippy/
